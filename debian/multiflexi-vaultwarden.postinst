#!/bin/sh
# postinst script for multiflexi-vaultwarden
set -e

case "$1" in
    configure)
        if [ -x /usr/bin/multiflexi-cli ]; then
            multiflexi-cli crprototype sync || true
        fi
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
